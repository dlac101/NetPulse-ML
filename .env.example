# NetPulse ML Backend Configuration

# Database (TimescaleDB)
DATABASE_URL=postgresql+asyncpg://netpulse:netpulse@localhost:5432/netpulse_ml

# Redis
REDIS_URL=redis://localhost:6379/0

# MQTT Broker
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPICS=smartos/+/bbst,smartos/+/qoe,smartos/+/classifi,smartos/+/flowstatd/#,smartos/+/wifi,smartos/+/events,smartos/+/meta

# MLflow Tracking
MLFLOW_TRACKING_URI=http://localhost:5000

# Model Artifacts
MODEL_DIR=./models

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
LOG_LEVEL=info

# Prediction Cache TTL (seconds)
CACHE_TTL_ANOMALY=300
CACHE_TTL_CHURN=3600
CACHE_TTL_FORECAST=900
